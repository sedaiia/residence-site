---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Sedaiia Residence" currentPath="/contact">
  <div class="page">
    <h2 class="heading">Let's work.</h2>

    <form id="contact-form">
      <input
        type="text"
        name="name"
        placeholder="Name"
        required
        class="field all"
      />
      <input
        type="text"
        name="company"
        placeholder="Company"
        class="field no-top"
      />
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="field no-top"
      />
      <div class="phone-row">
        <select name="countryCode" class="field no-top-no-right country-select">
          <option value="+1">+1</option>
          <option value="+44">+44</option>
          <option value="+31" selected>+31</option>
          <option value="+32">+32</option>
          <option value="+33">+33</option>
          <option value="+49">+49</option>
          <option value="+81">+81</option>
          <option value="+86">+86</option>
        </select>
        <input
          type="tel"
          name="phone"
          placeholder="Phone"
          class="field no-top-no-left phone-input"
        />
      </div>
      <textarea
        name="message"
        placeholder="Message"
        required
        rows="3"
        class="field no-top"
      ></textarea>

      <button type="submit" id="submit-btn" class="submit-btn">
        <span id="btn-label">Submit</span>
        <svg id="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M7 17L17 7M17 7H8M17 7V16" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p id="error-msg" class="error-msg" style="display:none;">
        Something went wrong. Please try again or email directly.
      </p>

      <p class="privacy-note">
        By submitting this form you agree to our
        <a href="https://sedaiia.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>.
        Your data is used solely to respond to your inquiry.
      </p>
    </form>
  </div>
</Layout>

<style>
  .page {
    max-width: 580px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .page { padding: 0 48px; }
  }

  .heading {
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 32px;
  }

  /* Dotted borders */
  .field {
    width: 100%;
    background: transparent;
    color: #fff;
    font-family: 'Courier New', Courier, monospace;
    font-size: 14px;
    font-weight: 400;
    padding: 12px 16px;
    border: none;
    outline: none;
    display: block;
    transition: background 0.2s;
  }
  .field::placeholder { color: rgba(255,255,255,0.4); }
  .field:focus { background: rgba(255,255,255,0.05); }

  .all {
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px);
    background-size: 6px 1px, 6px 1px, 1px 6px, 1px 6px;
    background-position: 0 0, 0 100%, 0 0, 100% 0;
    background-repeat: repeat-x, repeat-x, repeat-y, repeat-y;
  }
  .no-top {
    margin-top: -1px;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px);
    background-size: 6px 1px, 1px 6px, 1px 6px;
    background-position: 0 100%, 0 0, 100% 0;
    background-repeat: repeat-x, repeat-y, repeat-y;
  }

  /* Phone row */
  .phone-row {
    display: flex;
    margin-top: -1px;
  }
  .country-select {
    width: auto;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px);
    background-size: 6px 1px, 1px 6px;
    background-position: 0 100%, 0 0;
    background-repeat: repeat-x, repeat-y;
  }
  .country-select option { background: #000; }
  .phone-input {
    flex: 1;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px),
      repeating-linear-gradient(180deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 1px, transparent 6px);
    background-size: 6px 1px, 1px 6px;
    background-position: 0 100%, 100% 0;
    background-repeat: repeat-x, repeat-y;
  }

  /* Submit */
  .submit-btn {
    width: 100%;
    margin-top: -1px;
    background: #fff;
    color: #000;
    border: none;
    padding: 16px 24px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: background 0.2s;
  }
  .submit-btn:hover { background: #FFCC00; }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .submit-btn:hover #btn-arrow { transform: rotate(45deg); }
  #btn-arrow { transition: transform 0.2s; }

  .error-msg {
    color: #f87171;
    font-size: 13px;
    margin-top: 12px;
    font-family: 'Courier New', Courier, monospace;
  }

  .privacy-note {
    color: rgba(255,255,255,0.3);
    font-size: 11px;
    margin-top: 16px;
    font-family: 'Courier New', Courier, monospace;
    line-height: 1.6;
  }
  .privacy-note a {
    color: inherit;
    text-decoration: underline;
  }
  .privacy-note a:hover { color: rgba(255,255,255,0.6); }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label')!;
  const btnArrow = document.getElementById('btn-arrow')!;
  const errorMsg = document.getElementById('error-msg')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btnLabel.textContent = 'Sending...';
    btnArrow.style.display = 'none';
    errorMsg.style.display = 'none';

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      company: (form.elements.namedItem('company') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      countryCode: (form.elements.namedItem('countryCode') as HTMLSelectElement).value,
      phone: (form.elements.namedItem('phone') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error();
      btnLabel.textContent = 'Sent.';
      form.reset();
    } catch {
      btn.disabled = false;
      btnLabel.textContent = 'Submit';
      btnArrow.style.display = 'block';
      errorMsg.style.display = 'block';
    }
  });
</script>
