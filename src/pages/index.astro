---
import Layout from '../layouts/Layout.astro';
import { createClient } from '@sanity/client';

const client = createClient({
  projectId: 'drbqows2',
  dataset: 'production',
  useCdn: true,
  apiVersion: '2024-01-01',
});

interface ShowreelVideo {
  _key?: string;
  url: string;
  caption?: string;
}

let videos: ShowreelVideo[] = [];

try {
  const data = await client.fetch<{ videos?: ShowreelVideo[] }>(
    `*[_type == "residenceShowreel" && _id == "residenceShowreel"][0]{ videos[]{ _key, url, caption } }`
  );
  videos = data?.videos ?? [];
} catch {}

function getYouTubeId(url: string): string | null {
  const match = url.match(
    /(?:(?:www\.|m\.)?youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]+)/
  );
  return match ? match[1] : null;
}

function isDirectVideo(url: string): boolean {
  return /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url) || url.includes('blob.vercel-storage.com');
}
---

<Layout title="Sedaiia Residence" currentPath="/">
  <div class="page">
    {videos.length === 0 ? (
      <div class="empty-state">
        <div class="empty-placeholder"></div>
      </div>
    ) : (
      <div class="video-list">
        {videos.map((video, i) => {
          const youtubeId = getYouTubeId(video.url);
          const isShort = video.url.includes('/shorts/');
          const direct = !youtubeId && isDirectVideo(video.url);

          if (!youtubeId && !direct) return null;

          return (
            <div class="video-item" key={video._key ?? i}>
              {youtubeId ? (
                <div class={isShort ? 'embed-wrap short' : 'embed-wrap'}>
                  <iframe
                    src={`https://www.youtube.com/embed/${youtubeId}?controls=0&rel=0&iv_load_policy=3&modestbranding=1`}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    title={video.caption ?? `Video ${i + 1}`}
                  />
                </div>
              ) : (
                <div class="embed-wrap">
                  <video
                    src={video.url}
                    autoplay
                    muted
                    loop
                    playsinline
                    controls
                  />
                </div>
              )}
              {video.caption && (
                <p class="caption">{video.caption}</p>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
</Layout>

<style>
  .page {
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .page { padding: 0 48px; }
  }

  .empty-state {
    display: flex;
    justify-content: center;
  }
  .empty-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background: rgba(56,56,56,0.08);
  }

  .video-list {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .video-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .embed-wrap {
    width: min(100%, calc((100vh - 180px) * 16 / 9));
    aspect-ratio: 16/9;
    position: relative;
  }
  .embed-wrap.short {
    aspect-ratio: 9/16;
    max-width: 380px;
  }

  .embed-wrap iframe,
  .embed-wrap video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .caption {
    width: min(100%, calc((100vh - 180px) * 16 / 9));
    margin-top: 16px;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(56,56,56,0.5);
    font-family: Helvetica, Arial, sans-serif;
    text-align: center;
  }
</style>
